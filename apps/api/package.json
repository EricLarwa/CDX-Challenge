{
  "name": "@financeos/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --filter @financeos/shared build && bun --filter @financeos/db build && tsc -p tsconfig.json",
    "build:vercel": "bun --filter @financeos/db db:deploy && bun run build",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "start": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@financeos/db": "workspace:*",
    "@financeos/shared": "workspace:*",
    "@react-pdf/renderer": "^4.3.0",
    "react": "^19.1.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "node-cron": "^4.2.1",
    "resend": "^4.3.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3"
  }
}
