# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/financeos"

# Auth
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# API
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# AI
ANTHROPIC_API_KEY="sk-ant-..."
AI_ENABLED=true

# Email
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@financeos.app"

# File Storage
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
